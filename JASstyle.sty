\newcommand{\nn}{\newline\noindent}

% ---- Codeblock styling ----
% ---------------------------
\lstdefinestyle{base-clean}{
    basicstyle=\ttfamily\small,
    frame=single,
    rulecolor=\color{grayframe},
    breaklines=true,
    captionpos=b,
    numbers=left,
    numberstyle=\scriptsize\color{gray},
    tabsize=4,
    showstringspaces=false,
}

% ------- Custom boxes -------
% ----------------------------
\newtcbox{\gitBranchInline}{
  on line,
  colback=darkgrayframe,
  colframe=darkgrayframe,
  coltext=white,
  arc=2pt,
  boxsep=1pt,
  left=2pt,
  right=2pt,
  top=1pt,
  bottom=1pt,
  fontupper=\ttfamily
}

\newtcbox{\inlineCodeBlock}{
  on line,
  colback=bggray,
  colframe=bggray,
  coltext=lightgray,
  arc=1pt,
  boxsep=1pt,
  left=2pt,
  right=2pt,
  top=1pt,
  bottom=1pt,
  fontupper=\ttfamily
}

\newtcolorbox{infoBox}{
    enhanced,
    colback=red!10,
    colframe=red,
    boxrule=0pt,
    borderline west={2pt}{0pt}{red},
    sharp corners,
    rounded corners=southeast,
    arc=2mm,
    drop shadow,
    left= 10mm, right=2mm, top=2mm, bottom=2mm,
    % The Icon Overlay
    overlay={
        \node[anchor=north west, xshift=2mm, yshift=-0.75mm] 
        at (frame.north west) 
        {\Large\textcolor{red}{\faInfoCircle}};
    }
}

\newtcolorbox{worddefinition}[1]{
    enhanced,
    boxrule=1pt,
    arc=2mm,
    colback=boxbg,
    colframe=boxborder,
    fontupper=\normalsize,
    % upper box
    attach boxed title to top left={xshift=3mm, yshift=-3mm, yshifttext=-1mm},
    boxed title style={
        colback=boxheader,
        colframe=boxheader,
        arc=1.5mm,
        outer arc=1mm,
    },
    title={Definition},
    % Fcontent
    before upper={\textbf{\large\textcolor{wordcolor}{#1}}\\[0.4em]}
}

